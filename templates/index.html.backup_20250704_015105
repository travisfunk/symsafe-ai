<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>SymSafe AI – Healthcare Triage Assistant</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body {
      background-color: #f0f2f5;
      height: 100vh;
      overflow: hidden;
    }
    
    .chat-container {
      max-width: 800px;
      height: 100vh;
      margin: 0 auto;
      background: white;
      display: flex;
      flex-direction: column;
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
    }
    
    .chat-header {
      background: #075e54;
      color: white;
      padding: 15px 20px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    
    .chat-header h1 {
      font-size: 1.5rem;
      margin: 0;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    
    .voice-toggle {
      display: flex;
      align-items: center;
      gap: 10px;
      background: rgba(255,255,255,0.2);
      padding: 8px 15px;
      border-radius: 20px;
      cursor: pointer;
    }
    
    .voice-toggle:hover {
      background: rgba(255,255,255,0.3);
    }
    
    .chat-messages {
      flex: 1;
      overflow-y: auto;
      padding: 20px;
      background: #e5ddd5;
      background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23d5d5d5' fill-opacity='0.2'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    }
    
    .message {
      margin-bottom: 15px;
      display: flex;
      align-items: flex-end;
      animation: fadeIn 0.3s ease-in;
    }
    
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
    
    .message.user {
      justify-content: flex-end;
    }
    
    .message-bubble {
      max-width: 70%;
      padding: 10px 15px;
      border-radius: 18px;
      position: relative;
      word-wrap: break-word;
    }
    
    .message.user .message-bubble {
      background: #dcf8c6;
      border-bottom-right-radius: 4px;
    }
    
    .message.assistant .message-bubble {
      background: white;
      border-bottom-left-radius: 4px;
      box-shadow: 0 1px 2px rgba(0,0,0,0.1);
    }
    
    .message-time {
      font-size: 0.75rem;
      color: #667781;
      margin-top: 2px;
      text-align: right;
    }
    
    .message.assistant .message-time {
      text-align: left;
    }
    
    .speaking-indicator {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      color: #25d366;
      font-size: 0.875rem;
      margin-left: 10px;
    }
    
    .chat-input {
      padding: 15px;
      background: #f0f2f5;
      border-top: 1px solid #e1e4e8;
      display: flex;
      gap: 10px;
      align-items: center;
    }
    
    .chat-input input {
      flex: 1;
      padding: 10px 15px;
      border: 1px solid #ddd;
      border-radius: 25px;
      outline: none;
      font-size: 1rem;
    }
    
    .chat-input input:focus {
      border-color: #25d366;
    }
    
    .chat-input button {
      border: none;
      background: #25d366;
      color: white;
      padding: 10px 20px;
      border-radius: 25px;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 5px;
      transition: background 0.2s;
    }
    
    .chat-input button:hover {
      background: #20c659;
    }
    
    .chat-input button:disabled {
      background: #ccc;
      cursor: not-allowed;
    }
    
    .welcome-message {
      text-align: center;
      color: #667781;
      padding: 40px 20px;
    }
    
    .welcome-message h2 {
      color: #075e54;
      margin-bottom: 10px;
    }
    
    .example-symptoms {
      margin-top: 20px;
    }
    
    .example-symptoms button {
      margin: 5px;
      padding: 8px 15px;
      border: 1px solid #ddd;
      background: white;
      border-radius: 20px;
      cursor: pointer;
      transition: all 0.2s;
    }
    
    .example-symptoms button:hover {
      background: #f0f2f5;
      border-color: #25d366;
    }
    
    .listening-indicator {
      color: #e74c3c;
      display: flex;
      align-items: center;
      gap: 5px;
    }
    
    .pulse {
      display: inline-block;
      width: 8px;
      height: 8px;
      background: #e74c3c;
      border-radius: 50%;
      animation: pulse 1.5s ease-in-out infinite;
    }
    
    @keyframes pulse {
      0% { transform: scale(1); opacity: 1; }
      50% { transform: scale(1.2); opacity: 0.7; }
      100% { transform: scale(1); opacity: 1; }
    }
  </style>
</head>
<body>
  <div class="chat-container">
    <!-- Header -->
    <div class="chat-header">
      <h1>
        <span>🩺</span>
        SymSafe AI
      </h1>
      <div class="voice-toggle" onclick="toggleVoice()" id="voiceToggle">
        <span id="voiceIcon">🔊</span>
        <span id="voiceText">Voice On</span>
      </div>
    </div>
    
    <!-- Messages Area -->
    <div class="chat-messages" id="chatMessages">
      <div class="welcome-message" id="welcomeMessage">
        <h2>Welcome to SymSafe AI</h2>
        <p>I'm here to help you understand your symptoms and guide you to appropriate care.</p>
        <p class="text-muted">Remember: I'm not a doctor and cannot diagnose. Always consult a healthcare provider for medical advice.</p>
        
        <div class="example-symptoms">
          <p>Try saying or typing:</p>
          <button onclick="sendExample('I have a headache')">I have a headache</button>
          <button onclick="sendExample('I feel dizzy')">I feel dizzy</button>
          <button onclick="sendExample('My child has a fever')">My child has a fever</button>
        </div>
      </div>
    </div>
    
    <!-- Input Area -->
    <div class="chat-input">
      <input 
        type="text" 
        id="symptomInput" 
        placeholder="Type your symptom or question..." 
        onkeypress="handleKeyPress(event)"
      >
      <button onclick="sendMessage()" id="sendButton">
        <span>Send</span>
      </button>
      <button onclick="startVoice()" id="voiceButton">
        <span>🎤</span>
      </button>
    </div>
  </div>

  <!-- Include voice functions -->
  <script src="/static/js/voice-functions.js"></script>

  <script>
    let messageHistory = [];
    
    function handleKeyPress(event) {
      if (event.key === 'Enter') {
        sendMessage();
      }
    }
    
    function sendExample(text) {
      document.getElementById('symptomInput').value = text;
      sendMessage();
    }
    
    function sendMessage() {
      const input = document.getElementById('symptomInput').value.trim();
      if (!input) return;
      
      // Hide welcome message on first interaction
      const welcomeMsg = document.getElementById('welcomeMessage');
      if (welcomeMsg) {
        welcomeMsg.style.display = 'none';
      }
      
      // Add user message to chat
      addMessage(input, 'user');
      
      // Clear input
      document.getElementById('symptomInput').value = '';
      
      // Disable send button temporarily
      document.getElementById('sendButton').disabled = true;
      
      // Send to API
      fetch('/api/symptom', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ text: input })
      })
      .then(res => res.json())
      .then(data => {
        const response = data.response || "I'm having trouble understanding. Could you please rephrase that?";
        addMessage(response, 'assistant');
        
        // Speak response if voice is enabled
        if (voiceEnabled) {
          speakResponse(response);
        }
        
        // Re-enable send button
        document.getElementById('sendButton').disabled = false;
        
        // Focus back on input
        document.getElementById('symptomInput').focus();
      })
      .catch(err => {
        addMessage("I'm sorry, I'm having technical difficulties. Please try again.", 'assistant');
        document.getElementById('sendButton').disabled = false;
      });
    }
    
    function addMessage(text, sender) {
      const messagesDiv = document.getElementById('chatMessages');
      const messageDiv = document.createElement('div');
      messageDiv.className = `message ${sender}`;
      
      const time = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
      
      messageDiv.innerHTML = `
        <div class="message-bubble">
          ${text}
          ${sender === 'assistant' && voiceEnabled ? '<span id="speaking-indicator" class="speaking-indicator" style="display:none;"><span class="pulse"></span> Speaking...</span>' : ''}
          <div class="message-time">${time}</div>
        </div>
      `;
      
      messagesDiv.appendChild(messageDiv);
      
      // Scroll to bottom
      messagesDiv.scrollTop = messagesDiv.scrollHeight;
      
      // Store in history
      messageHistory.push({ text, sender, time });
    }
    
    function startVoice() {
      const recognition = new (window.SpeechRecognition || window.webkitSpeechRecognition)();
      recognition.lang = "en-US";
      recognition.interimResults = false;
      recognition.maxAlternatives = 1;
      
      const voiceButton = document.getElementById('voiceButton');
      voiceButton.innerHTML = '<span class="listening-indicator"><span class="pulse"></span> Listening...</span>';
      voiceButton.disabled = true;
      
      recognition.onresult = event => {
        const speech = event.results[0][0].transcript;
        document.getElementById('symptomInput').value = speech;
        sendMessage();
      };
      
      recognition.onerror = event => {
        alert("Voice input error: " + event.error);
        resetVoiceButton();
      };
      
      recognition.onend = event => {
        resetVoiceButton();
      };
      
      recognition.start();
    }
    
    function resetVoiceButton() {
      const voiceButton = document.getElementById('voiceButton');
      voiceButton.innerHTML = '<span>🎤</span>';
      voiceButton.disabled = false;
    }
    
    // Override the toggleVoice function to update our UI
    const originalToggleVoice = window.toggleVoice;
    window.toggleVoice = function() {
      originalToggleVoice();
      const icon = document.getElementById('voiceIcon');
      const text = document.getElementById('voiceText');
      
      if (voiceEnabled) {
        icon.textContent = '🔊';
        text.textContent = 'Voice On';
      } else {
        icon.textContent = '🔇';
        text.textContent = 'Voice Off';
      }
    };
    
    // Focus on input when page loads
    window.onload = function() {
      document.getElementById('symptomInput').focus();
    };
  </script>
</body>
</html>
