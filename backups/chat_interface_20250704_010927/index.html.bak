<!-- templates/index.html -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>SymSafe AI – Home</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <div class="container mt-5">
    <h1 class="mb-4">🩺 SymSafe AI</h1>
    <p class="lead">Welcome to the SymSafe AI triage system. Choose a symptom or ask a question below.</p>

    <div class="mb-3">
      <label for="symptomInput" class="form-label">Your symptom or question</label>
      <input type="text" class="form-control" id="symptomInput" placeholder="e.g. I have a sore throat and fever">
    </div>

    <button class="btn btn-primary" onclick="submitSymptom()">Submit</button>
    <button class="btn btn-outline-secondary ms-2" onclick="startVoice()">🎤 Talk to me</button>

    <hr class="my-5">
    <div id="responseArea" class="alert alert-info d-none"></div>
  </div>

  <script>
    function submitSymptom() {
      const input = document.getElementById("symptomInput").value.trim();
      if (!input) return;

      fetch('/api/symptom', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ text: input })
      })
      .then(res => res.json())
      .then(data => {
        const area = document.getElementById("responseArea");
        area.textContent = data.response || "No response generated.";
        area.classList.remove("d-none");
        
        // Store and speak response
        speakResponse(data.response || "No response generated.");
      })
      .catch(err => alert("Error: " + err.message));
    }

    function startVoice() {
      alert("Voice input not yet implemented. Coming soon!");
    }
  </script>
  <!-- Include voice functions -->
  <script src="/static/js/voice-functions.js"></script>
</body>
</html>

